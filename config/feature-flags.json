{
  "$schema": "./feature-flags.schema.json",
  "version": 1,
  "description": "CCN feature-flag registry. Phased/gated domains default OFF. Per-environment overrides are applied by the flag loader (added in a later milestone).",
  "flags": {
    "delivery": {
      "description": "Spynzo-backed delivery flow. Gated on OQ1/OQ2.",
      "default": false,
      "gated": true
    },
    "escrow": {
      "description": "Item-value escrow. Gated on legal clearance (OQ3).",
      "default": false,
      "gated": true
    },
    "swap": { "description": "Swap/barter (V1).", "default": false, "gated": false },
    "wishlists": { "description": "Demand marketplace (V1).", "default": false, "gated": false },
    "rentals": { "description": "Rentals (V2).", "default": false, "gated": true },
    "ai_assist": { "description": "AI pricing/description (V2).", "default": false, "gated": true },
    "community": { "description": "Campus community (V3).", "default": false, "gated": false },
    "rides": {
      "description": "Ride sharing (V3). Requires Level-2 verification + escrow.",
      "default": false,
      "gated": true
    },
    "notes_exchange": {
      "description": "Academic notes/PYQ (V3).",
      "default": false,
      "gated": false
    },
    "lost_and_found": { "description": "Lost & Found (V3).", "default": false, "gated": false }
  }
}
