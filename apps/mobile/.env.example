# ─────────────────────────────────────────────────────────────
# CCN mobile — CLIENT environment template.
# Only EXPO_PUBLIC_* vars are bundled into the app and are PUBLIC.
# Never place service-role keys or provider secrets here.
# ─────────────────────────────────────────────────────────────

EXPO_PUBLIC_APP_ENV=development

# Supabase (client, RLS-protected)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Observability (client)
EXPO_PUBLIC_SENTRY_DSN=https://PUBLIC_DSN@o0.ingest.sentry.io/0

# Maps (client) — key MUST be usage/referrer/bundle-id restricted
EXPO_PUBLIC_MAPS_API_KEY=YOUR_RESTRICTED_MAPS_KEY

# Payments (client checkout id — public by design)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Analytics (client)
EXPO_PUBLIC_ANALYTICS_KEY=YOUR_ANALYTICS_KEY

# Feature flags
EXPO_PUBLIC_FLAGS_SOURCE=local
