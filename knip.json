{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs", "eslint.config.mjs", "commitlint.config.cjs"],
      "project": ["**/*.{ts,mjs,cjs}"]
    },
    "apps/mobile": { "entry": ["index.ts", "app.config.ts"], "project": ["src/**/*.{ts,tsx}"] },
    "packages/*": { "entry": ["src/index.ts"], "project": ["src/**/*.{ts,tsx}"] }
  }
}
