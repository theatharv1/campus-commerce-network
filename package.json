{
  "name": "ccn",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Campus Commerce Network — monorepo root.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint:workspaces": "turbo run lint",
    "typecheck:workspaces": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "env:check": "node scripts/check-env.mjs",
    "install:ci": "pnpm install --frozen-lockfile",
    "audit": "pnpm audit --audit-level=moderate",
    "outdated": "pnpm outdated -r",
    "deps:dedupe": "pnpm dedupe --check",
    "deadcode": "knip"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import-x": "^4.5.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "knip": "^5.39.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "overrides": {},
    "peerDependencyRules": {
      "allowedVersions": {},
      "ignoreMissing": []
    }
  }
}
