# ─────────────────────────────────────────────────────────────
# CCN — root environment template (server & tooling scope).
# Copy to `.env` for local development. NEVER commit a real `.env`.
# Secrets for staging/production live in the managed secrets store.
# ─────────────────────────────────────────────────────────────

APP_ENV=development
NODE_ENV=development

# Supabase (server / tooling)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_SERVICE_ROLE_KEY=__SET_IN_SECRETS_STORE__
SUPABASE_JWT_SECRET=__SET_IN_SECRETS_STORE__
DATABASE_URL=postgresql://postgres:__SET_IN_SECRETS_STORE__@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Observability (CI/server)
SENTRY_ORG=ccn
SENTRY_PROJECT=ccn-backend
SENTRY_AUTH_TOKEN=__SET_IN_SECRETS_STORE__
LOG_LEVEL=info

# Payments (server) — delivery-fee only at MVP; escrow gated (OQ3)
RAZORPAY_KEY_SECRET=__SET_IN_SECRETS_STORE__
RAZORPAY_WEBHOOK_SECRET=__SET_IN_SECRETS_STORE__

# Push (server)
FIREBASE_SERVICE_ACCOUNT_JSON=__SET_IN_SECRETS_STORE__

# Analytics (server ingest)
ANALYTICS_WRITE_KEY=__SET_IN_SECRETS_STORE__

# Delivery — RESERVED, PENDING Spynzo integration (OQ1/OQ2)
SPYNZO_API_BASE_URL=
SPYNZO_API_KEY=
SPYNZO_WEBHOOK_SECRET=

# Notifications — RESERVED (later milestone)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EMAIL_PROVIDER_API_KEY=
